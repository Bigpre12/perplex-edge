# Copy to ".env" at the repo root (or use "apps/api/.env"; both are loaded — root first, then apps/api, then cwd with override).
# Production / Railway triage checklist: docs/RAILWAY_PRODUCTION.md
# Test Postgres from shell (asyncpg, same DSN rules as prod): cd apps/api/src && python scripts/test_asyncpg_connect.py
# https://supabase.com/dashboard/project/_/settings/database

# --- Backend Postgres (Supabase transaction pooler, port 6543) ---
# Use the "Shared Pooler" URI from Supabase (Transaction mode). Replace [YOUR-PASSWORD].
# Keep the scheme as postgresql:// (not postgresql+asyncpg://); apps/api normalizes for SQLAlchemy.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres

# If Alembic DDL fails through the transaction pooler, set a session/direct URL for migrations only
# and run: alembic -x sqlalchemy.url="$DATABASE_URL_MIGRATIONS" upgrade head
# DATABASE_URL_MIGRATIONS=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# --- Supabase client (browser + API helpers) ---
# Project URL and anon (publishable) key: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Optional: server-side defaults (falls back to NEXT_PUBLIC_* in apps/api/src/core/config.py)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_KEY=your-anon-or-publishable-key

# --- Railway / production: Redis (required for WebSocket pub/sub; not default localhost on Railway) ---
# REDIS_URL=redis://default:password@redis.railway.internal:6379
# In Railway, reference the Redis plugin URL via variable reference instead of hardcoding.

# --- The Odds API (at least one key source required in prod; see validate_env in main.py) ---
# ODDS_API_KEY=
# THE_ODDS_API_KEY=
# ODDS_API_KEY_BACKUP=
# ODDS_API_KEYS=key1,key2,key3

# --- Unified ingest scheduler (quota / polling) — see docs/RAILWAY_PRODUCTION.md ---
# Default: tiered (active sports more often than inactive). Legacy: all sports same interval.
# INGEST_USE_LEGACY_SCHEDULER=false
# INGEST_INTERVAL_MINUTES=5
# INGEST_INTERVAL_ACTIVE_MINUTES=30
# INGEST_INTERVAL_INACTIVE_HOURS=6
# INGEST_ACTIVE_SPORTS=basketball_nba,icehockey_nhl,soccer_usa_mls,soccer_epl,soccer_uefa_champs_league
# INGEST_INACTIVE_SPORTS=
# INGEST_DISABLED_SPORTS=
# SKIP_HEARTBEAT_WHEN_ODDS_KEYS_COOLDOWN=true

# --- Common API secrets (see config.py for full list) ---
# SECRET_KEY=
