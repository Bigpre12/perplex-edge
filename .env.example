# Copy to ".env" at the repo root (or use "apps/api/.env"; both are loaded — root first, then apps/api, then cwd with override).
# https://supabase.com/dashboard/project/_/settings/database

# --- Backend Postgres (Supabase transaction pooler, port 6543) ---
# Use the "Shared Pooler" URI from Supabase (Transaction mode). Replace [YOUR-PASSWORD].
# Keep the scheme as postgresql:// (not postgresql+asyncpg://); apps/api normalizes for SQLAlchemy.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres

# If Alembic DDL fails through the transaction pooler, set a session/direct URL for migrations only
# and run: alembic -x sqlalchemy.url="$DATABASE_URL_MIGRATIONS" upgrade head
# DATABASE_URL_MIGRATIONS=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# --- Supabase client (browser + API helpers) ---
# Project URL and anon (publishable) key: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Optional: server-side defaults (falls back to NEXT_PUBLIC_* in apps/api/src/core/config.py)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_KEY=your-anon-or-publishable-key

# --- Common API secrets (see config.py for full list) ---
# SECRET_KEY=
