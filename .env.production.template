# =============================================================================
# Perplex Edge — Production Environment Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit actual API keys to version control

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# Environment
ENVIRONMENT=production

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=perplex
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:your_secure_password_here@db:5432/perplex

# API Keys (REQUIRED)
ODDS_API_KEY=your_production_odds_api_key_here

# Frontend Configuration
FRONTEND_URL=https://your-app-name.up.railway.app
CORS_ORIGINS=https://your-app-name.up.railway.app
VITE_API_BASE_URL=https://your-backend-name.up.railway.app

# Service Ports
BACKEND_PORT=8000
FRONTEND_PORT=3000
REDIS_PORT=6379

# =============================================================================
# OPTIONAL FEATURES
# =============================================================================

# AI Integration (Groq)
AI_ENABLED=false
AI_API_KEY=your_production_groq_api_key_here
AI_API_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile

# Error Monitoring
SENTRY_DSN=your_production_sentry_dsn_here

# Caching
REDIS_URL=redis://redis:6379/0

# Scheduler Configuration
SCHEDULER_ENABLED=true
SCHEDULER_USE_STUBS=false

# =============================================================================
# OPTIONAL API INTEGRATIONS
# =============================================================================

# Additional APIs (Optional)
BETSTACK_API_KEY=your_betstack_api_key_here
ODDSPAPI_API_KEY=your_oddspapi_api_key_here
STATS_API_KEY=your_stats_api_key_here
INJURY_API_KEY=your_injury_api_key_here
ROSTER_API_KEY=your_roster_api_key_here

# =============================================================================
# WHOP INTEGRATION
# =============================================================================

WHOP_FREE_CHECKOUT_URL=https://whop.com/checkout/plan_WxHa3UGwMmjdd
WHOP_PRO_MONTHLY_CHECKOUT_URL=https://whop.com/checkout/plan_8Qztt62kvlW8y
WHOP_PRO_YEARLY_CHECKOUT_URL=https://whop.com/checkout/plan_eeIAyl9zqIhfb
VITE_WHOP_MONTHLY_URL=https://whop.com/checkout/your-monthly-plan
VITE_WHOP_YEARLY_URL=https://whop.com/checkout/your-yearly-plan

# =============================================================================
# DEPLOYMENT SPECIFIC
# =============================================================================

# Railway (if using Railway)
RAILWAY_ENVIRONMENT=production

# SSL/TLS (if using custom domain)
SSL_CERT_PATH=/etc/ssl/certs/your-cert.pem
SSL_KEY_PATH=/etc/ssl/private/your-key.pem

# =============================================================================
# MONITORING & LOGGING
# =============================================================================

# Logging Level
LOG_LEVEL=INFO

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# =============================================================================
# SECURITY
# =============================================================================

# Session Management
SESSION_SECRET=your_session_secret_here
JWT_SECRET=your_jwt_secret_here

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# =============================================================================
# BACKUP & MAINTENANCE
# =============================================================================

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# Maintenance
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE="System under maintenance. Please check back soon."
