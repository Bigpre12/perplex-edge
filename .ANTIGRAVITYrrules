━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  ✅ All migrations use IF NOT EXISTS / IF EXISTS — safe for re-runs
  ✅ New columns always nullable with a safe default: COALESCE in every query
  ✅ Index every foreign key column and sport_id for query performance
  ✅ Supabase connection string uses ?sslmode=require for production
