  ❌ NEVER use DROP TABLE or DROP COLUMN in a migration without a confirmed backup
  ❌ NEVER run raw ALTER TABLE in application code — use migrations only

MIGRATION TEMPLATE (copy for every new column)
  def upgrade():
      conn = op.get_bind()
      exists = conn.execute(sa.text(
          "SELECT 1 FROM information_schema.columns "
          "WHERE table_name='TABLE' AND column_name='COLUMN'"
      )).fetchone()
      if not exists:
          op.add_column("TABLE", sa.Column("COLUMN", sa.TYPE, nullable=True))

