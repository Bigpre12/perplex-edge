# Production Frontend Environment Variables
# Copy this file to .env and update with your actual values

# Backend API URL (REQUIRED)
# Update this to your production backend URL
VITE_API_BASE_URL=https://your-backend-url.up.railway.app

# Whop Integration (OPTIONAL)
# Update with your actual Whop checkout URLs
VITE_WHOP_MONTHLY_URL=https://whop.com/checkout/your-monthly-plan
VITE_WHOP_YEARLY_URL=https://whop.com/checkout/your-yearly-plan
