# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/perplex

# Environment
ENVIRONMENT=development

# The Odds API (Primary)
ODDS_API_KEY=your_odds_api_key_here
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4

# BetStack API (Secondary fallback - uses same format as Odds API)
BETSTACK_API_KEY=your_betstack_api_key_here
BETSTACK_API_BASE_URL=https://api.the-odds-api.com/v4

# OddsPapi API (Historical data & analytics)
# Get your API key at: https://oddspapi.io/
ODDSPAPI_API_KEY=your_oddspapi_api_key_here
ODDSPAPI_BASE_URL=https://api.oddspapi.io/v4

# Stats API
STATS_API_KEY=your_stats_api_key_here
STATS_API_BASE_URL=https://api.sportsstats.example.com/v1

# Injury API
INJURY_API_KEY=your_injury_api_key_here
INJURY_API_BASE_URL=https://api.injurytracker.example.com/v1

# Roster API (balldontlie.io - free NBA API)
# Get your API key at: https://www.balldontlie.io/
ROSTER_API_KEY=your_roster_api_key_here
ROSTER_API_BASE_URL=https://api.balldontlie.io/v1

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Scheduler Configuration
# Set to false to disable background ETL tasks (useful for migrations/debugging)
SCHEDULER_ENABLED=true
# Use stub data for scheduled syncs (set to false to use real APIs with valid keys)
SCHEDULER_USE_STUBS=true

# Scheduler Intervals (optimized for Odds API free tier: 500 requests/month)
# These hourly intervals use ~720 requests/month, within free tier limits
# Reduce intervals if you have a paid Odds API plan for more frequent updates
SCHED_ODDS_INTERVAL_MIN=60
SCHED_STATS_INTERVAL_MIN=60
SCHED_MODEL_INTERVAL_MIN=60
SCHED_ROSTER_INTERVAL_HOURS=24

# Daily Refresh Configuration
# Daily refresh time (hour in 24h format, EST timezone)
DAILY_REFRESH_HOUR=9
# Hourly odds check interval (minutes)
HOURLY_CHECK_INTERVAL=60

# NFL-specific Configuration
# Sync interval for NFL odds (minutes)
NFL_SYNC_INTERVAL_MIN=60
# Daily snapshot hour (EST timezone, 24h format)
NFL_SNAPSHOT_HOUR=6
# Directory for JSON backups
NFL_BACKUP_DIR=backups

# NCAAB-specific Configuration
# Sync interval for NCAAB odds (minutes)
NCAAB_SYNC_INTERVAL_MIN=60
# Daily snapshot hour (EST timezone, 24h format)
NCAAB_SNAPSHOT_HOUR=6
# Directory for JSON backups
NCAAB_BACKUP_DIR=backups
