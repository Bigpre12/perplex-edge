# =============================================================================
# Perplex Edge — Production Environment Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit actual API keys to version control

# Environment
ENVIRONMENT=production

# Database (Railway PostgreSQL or your production database)
DATABASE_URL=postgresql+psycopg://username:password@host:port/database

# The Odds API (Primary) - REQUIRED
# Get your key at: https://the-odds-api.com/
ODDS_API_KEY=your_production_odds_api_key_here
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4

# BetStack API (Secondary fallback) - OPTIONAL
BETSTACK_API_KEY=your_production_betstack_api_key_here
BETSTACK_API_BASE_URL=https://api.the-odds-api.com/v4

# OddsPapi API (Historical data & analytics) - OPTIONAL
# Get your key at: https://oddspapi.io/
ODDSPAPI_API_KEY=your_production_oddspapi_api_key_here
ODDSPAPI_BASE_URL=https://api.oddspapi.io/v4

# Stats API - OPTIONAL
STATS_API_KEY=your_production_stats_api_key_here
STATS_API_BASE_URL=https://api.sportsstats.example.com/v1

# Injury API - OPTIONAL
INJURY_API_KEY=your_production_injury_api_key_here
INJURY_API_BASE_URL=https://api.injurytracker.example.com/v1

# Roster API (balldontlie.io - free NBA API) - OPTIONAL
# Get your key at: https://www.balldontlie.io/
ROSTER_API_KEY=your_production_roster_api_key_here
ROSTER_API_BASE_URL=https://api.balldontlie.io/v1

# Frontend URL (for CORS) - UPDATE THIS
FRONTEND_URL=https://your-production-frontend-url.com

# Additional CORS origins (comma-separated) - UPDATE THESE
CORS_ORIGINS=https://your-production-frontend-url.com,https://admin.your-domain.com

# Discord Webhook (for alerts) - OPTIONAL
# Create a webhook at: Discord Server Settings > Integrations > Webhooks > New Webhook
DISCORD_WEBHOOK_URL=

# AI Integration (Groq) - OPTIONAL
# Get your key at: https://console.groq.com/keys
AI_ENABLED=false
AI_API_KEY=your_production_groq_api_key_here
AI_API_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=2

# Sentry DSN for error monitoring - RECOMMENDED
# Get your DSN at: https://sentry.io/
SENTRY_DSN=

# Redis URL for caching - OPTIONAL
# Leave empty to use in-memory caching
REDIS_URL=redis://username:password@host:port/database

# Scheduler Configuration
SCHEDULER_ENABLED=true
SCHEDULER_USE_STUBS=false

# Scheduler Intervals (optimize for your API plan limits)
SCHED_ODDS_INTERVAL_MIN=60
SCHED_STATS_INTERVAL_MIN=60
SCHED_MODEL_INTERVAL_MIN=60
SCHED_ROSTER_INTERVAL_HOURS=24

# Daily Refresh Configuration
DAILY_REFRESH_HOUR=6
HOURLY_CHECK_INTERVAL=60

# NFL-specific Configuration
NFL_SYNC_INTERVAL_MIN=60
NFL_SNAPSHOT_HOUR=6
NFL_BACKUP_DIR=backups

# NCAAB-specific Configuration
NCAAB_SYNC_INTERVAL_MIN=60
NCAAB_SNAPSHOT_HOUR=6
NCAAB_BACKUP_DIR=backups

# Whop Integration
WHOP_FREE_CHECKOUT_URL=https://whop.com/checkout/plan_WxHa3UGwMmjdd
WHOP_PRO_MONTHLY_CHECKOUT_URL=https://whop.com/checkout/plan_8Qztt62kvlW8y
WHOP_PRO_YEARLY_CHECKOUT_URL=https://whop.com/checkout/plan_eeIAyl9zqIhfb

# Production-specific settings
PORT=8000
LOG_LEVEL=INFO
