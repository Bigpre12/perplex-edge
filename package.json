{
  "name": "perplex-edge",
  "version": "1.0.0",
  "description": "Sports Betting Intelligence Platform",
  "main": "index.html",
  "scripts": {
    "dev": "concurrently \"npm run api\" \"npm run web\"",
    "api": "cd apps/api && py run_api.py",
    "web": "cd apps/web && npm run dev",
    "lint": "npm run lint:web",
    "lint:web": "cd apps/web && npm run lint",
    "install-all": "npm install && cd apps/web && npm install && cd ../api && py -m pip install -r requirements.txt"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "keywords": [
    "sports-betting",
    "fastapi",
    "python"
  ],
  "author": "",
  "license": "ISC"
}
